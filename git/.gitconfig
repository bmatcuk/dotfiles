[alias]
  lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cblue(%aN)%Creset %Cgreen(%cr)%Creset' --abbrev-commit --date=relative
  lgf = "!_() { local SHA=`git lg | fzf --no-sort --ansi | sed 's/^[^a-z0-9]*//;/^$/d' | awk '{print $1}'`; [ -n \"${SHA}\" ] && git show ${SHA}; }; _"
  new = !bash -c 'git lg $1@{1}..$1@{0} "$@"'
  show-deleted = "!_() { local HASH=`git rev-list --max-count=1 --all -- $1`; git show ${HASH}^:$1; }; _"
  gone-branches = "!_() { git branch -vv | awk '$3 $4 ~ /:gone/ { print $1 }'; }; _"
  check-conflicts = "!_() { set -x; local BRANCH=${1-master}; local BASE=`git merge-base HEAD $BRANCH`; git format-patch $BASE..$BRANCH --stdout | git apply --3way --check -; }; _"
  root = "!pwd"

[core]
  pager = delta

[pager]
	diff = diffnav

[diff-so-fancy]
  stripLeadingSymbols = false

[push]
  default = current
  followTags = true

[pull]
	rebase = true

[fetch]
  prune = true

[merge]
  tool = nvimdiff
  conflictstyle = zdiff3

[merge "npm-merge-driver"]
  name = automatically merge npm lockfiles
  driver = npx npm-merge-driver merge %A %O %B %P

[merge "yarn-merge-driver"]
  name = automatically merge yarn lockfiles
  driver = npx npm-merge-driver merge %A %O %B %P -c yarn

[mergetool]
  keepBackup = false

[mergetool "nvimdiff"]
  layout = "LOCAL,BASE,REMOTE / MERGED"

[interactive]
  diffFilter = delta --color-only

[submodule]
  recurse = true

[color.advice]
  # Color for advice/hint messages
  hint = yellow

[color.blame]
  highlightRecent = "blue,12 month ago,white,1 month ago,red"

[color.branch]
  # Colors for git branch output
  current = green
  local = normal
  remote = white
  upstream = blue
  plain = normal
  worktree = cyan

[color.decorate]
  # Colors for ref decorations in git log
  branch = bold green
  remoteBranch = bold white
  tag = bold yellow
  stash = bold magenta
  HEAD = bold cyan
  grafted = bold blue

[color.diff]
  # Colors for git diff output
  context = normal
  meta = bold
  frag = cyan
  func = normal
  old = red
  new = green
  commit = yellow
  whitespace = red reverse

  # Colors for moved line detection
  oldMoved = bold magenta
  oldMovedAlternative = bold blue
  oldMovedDimmed = dim
  oldMovedAlternativeDimmed = dim italic
  newMoved = bold cyan
  newMovedAlternative = bold yellow
  newMovedDimmed = dim
  newMovedAlternativeDimmed = dim italic

  # Dimmed variants
  contextDimmed = dim
  oldDimmed = dim red
  newDimmed = dim green

  # Bold variants
  contextBold = bold
  oldBold = bold red
  newBold = bold green

[color.grep]
  # Colors for git grep output
  context = default
  filename = magenta
  function = default
  lineNumber = green
  column = default
  match = bold red
  matchContext = bold red
  matchSelected = bold red
  selected = default
  separator = cyan

[color.interactive]
  # Colors for interactive commands (git add -i, git clean -i)
  prompt = bold blue
  header = bold
  help = bold red
  error = bold red

[color.push]
  # Colors for git push output
  error = red

[color.remote]
  hint = white
  warning = yellow
  success = green
  error = red

[color.status]
  # Colors for git status output
  header = normal
  added = green
  updated = green
  changed = red
  untracked = red
  noBranch = red
  unmerged = red
  localBranch = green
  remoteBranch = red
  branch = default

[color.transport]
  rejected = red

[include]
  path = .gitconfig.local

[init]
	defaultBranch = main

# Frappe with Mocha surfaces, overlays, and base
[delta "catppuccin-frappe"]
	blame-palette = "#1e1e2e #181825 #11111b #313244 #45475a"
	commit-decoration-style = "#6c7086" bold box ul
	dark = true
	file-decoration-style = "#6c7086"
	file-style = "#c6d0f5"
	hunk-header-decoration-style = "#6c7086" box ul
	hunk-header-file-style = bold
	hunk-header-line-number-style = bold "#a5adce"
	hunk-header-style = file line-number syntax
	line-numbers-left-style = "#6c7086"
	line-numbers-minus-style = bold "#e78284"
	line-numbers-plus-style = bold "#a6d189"
	line-numbers-right-style = "#6c7086"
	line-numbers-zero-style = "#6c7086"
	# 36% red 64% base
	minus-emph-style = bold syntax "#66424d"
	# 18% red 82% base
	minus-style = syntax "#42303d"
	# 36% green 64% base
	plus-emph-style = bold syntax "#4f5e4f"
	# 18% green 82% base
	plus-style = syntax "#363e3e"
	map-styles = \
		bold purple => syntax "#66597e", \
		bold blue => syntax "#505d81", \
		bold cyan => syntax "#546b7a", \
		bold yellow => syntax "#6f6860"
	# Should match the name of the bat theme
	syntax-theme = Catppuccin Frappe

[delta]
  features = catppuccin-frappe
  navigate = true
  tabs = 2
  line-numbers = true
